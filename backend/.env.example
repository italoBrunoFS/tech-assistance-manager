DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Authentication
AUTH_TOKEN_SECRET=change_me_to_a_long_random_secret
AUTH_TOKEN_EXPIRES_HOURS=12

# WhatsApp Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_SIMULATION_MODE=true
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_TOKEN=
WHATSAPP_DEFAULT_COUNTRY_CODE=55

# Email
EMAIL_ENABLED=false
EMAIL_PROVIDER=ethereal
EMAIL_FROM=Assistencia Tecnica <no-reply@assistencia.local>

# Gmail SMTP
EMAIL_GMAIL_USER=
EMAIL_GMAIL_APP_PASSWORD=

# Ethereal
EMAIL_ETHEREAL_HOST=smtp.ethereal.email
EMAIL_ETHEREAL_PORT=587
EMAIL_ETHEREAL_SECURE=false
EMAIL_ETHEREAL_USER=
EMAIL_ETHEREAL_PASS=
